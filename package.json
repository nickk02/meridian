{
  "name": "meridian",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --config wrangler.local.jsonc",
    "build": "vite build",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.worker.json --noEmit",
    "deploy": "wrangler deploy",
    "migrate:local": "wrangler d1 migrations apply DB --config wrangler.local.jsonc --local",
    "migrate:remote": "wrangler d1 migrations apply meridian-db --remote"
  },
  "dependencies": {
    "@blueprintjs/core": "^5.16.0",
    "@blueprintjs/icons": "^5.21.0",
    "@blueprintjs/select": "^5.3.0",
    "@blueprintjs/table": "^5.3.0",
    "@deck.gl/core": "^9.3.3",
    "@deck.gl/layers": "^9.3.3",
    "@deck.gl/mapbox": "^9.3.3",
    "@fontsource/chakra-petch": "^5.2.7",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "d3-force": "^3.0.0",
    "hono": "^4.7.0",
    "maplibre-gl": "^5.24.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "satellite.js": "^5.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250604.0",
    "@types/d3-force": "^3.0.10",
    "@types/geojson": "^7946.0.16",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "wrangler": "^4.98.0"
  }
}
